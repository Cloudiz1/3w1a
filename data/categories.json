      "max": 100,
      "step": 1
    },
    {
      "name": "height_cm",
      "type": "range",
      "min": 0,
      "max": 300 
    },
    {
      "name": "weight_kg",
      "type": "range",
      "min": 100,
      "max": 1000
    },
    {
      "name": "Blood Pressure",
